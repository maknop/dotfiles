# Path to your oh-my-zsh installation.
export ZSH=$HOME/.oh-my-zsh

alias python=python3
alias pip=pip3

# Theme for oh-my-zsh
# Link: https://github.com/dikiaap/dotfiles/blob/master/.oh-my-zsh/themes/oxide.zsh-theme
ZSH_THEME="oxide"

# Plugins loaded
plugins=(git)

# oh-my-zsh
source $ZSH/oh-my-zsh.sh
