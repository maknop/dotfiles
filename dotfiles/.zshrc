# Path to your oh-my-zsh installation.
export ZSH="/Users/madeo/.oh-my-zsh"

# Theme for oh-my-zsh
# Link: https://github.com/dikiaap/dotfiles/blob/master/.oh-my-zsh/themes/oxide.zsh-theme
ZSH_THEME="oxide"

# Case-sensitive completion
CASE_SENSITIVE="true"

# Plugins loaded
plugins=(git)

# oh-my-zsh
source $ZSH/oh-my-zsh.sh

# tmux
source ~/tmux.sh
